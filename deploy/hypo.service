[Unit]
Description=Mortgage Refinance Calculator (Streamlit)
After=network.target

[Service]
User=flaim
WorkingDirectory=/www/hypo
EnvironmentFile=/www/hypo/.env
ExecStart=/www/hypo/.venv/bin/streamlit run main.py \
    --server.port=8501 \
    --server.address=127.0.0.1 \
    --server.headless=true \
    --browser.gatherUsageStats=false
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
